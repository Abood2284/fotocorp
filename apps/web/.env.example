# Set to "true" on production to show /under-construction for all visitors (see middleware).
# Optional: set a long random secret and visit https://your-domain/?preview=<secret> once to preview the real site (7-day cookie).
SITE_UNDER_CONSTRUCTION=false
# SITE_UNDER_CONSTRUCTION_BYPASS_SECRET=replace-with-long-random-preview-secret

# Public API origin used by web pages and signed preview image URLs.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8787
# Server-side catalog + preview URL base (OpenNext/Cloudflare: set in Wrangler vars so SSR is not
# stuck with an empty NEXT_PUBLIC_* value baked in at build time).
PUBLIC_API_BASE_URL=http://127.0.0.1:8787
# Server-only internal API origin/secret for protected admin catalog calls and /api/auth/* proxy.
# Must match the Worker dev listen address (repo root: `pnpm dev:api` → port 8787; see apps/api/package.json).
INTERNAL_API_BASE_URL=http://127.0.0.1:8787
# Must match INTERNAL_API_SECRET in apps/api/.dev.vars (or Wrangler secrets) exactly.
INTERNAL_API_SECRET=replace-with-long-random-internal-secret
NEXT_PUBLIC_ASSET_DATA_SOURCE=auto
# Feature-flagged /search cutover. true => /api/public/search/assets (Typesense-backed);
# false/empty => legacy SQL-backed /api/v1/assets + /api/v1/assets/filters.
NEXT_PUBLIC_USE_TYPESENSE_SEARCH=false
# Better Auth session reads use the same secret/database as the API-owned /api/auth/* handler.
# Must match BETTER_AUTH_SECRET in apps/api/.dev.vars.
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@host:5432/database
FOTOCORP_SUPER_ADMIN_EMAIL=admin@example.com
