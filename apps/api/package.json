    "smoke:photographer-auth": "tsx scripts/smoke/check-photographer-auth.ts",
    "smoke:photographer-analytics": "tsx scripts/smoke/check-photographer-analytics.ts",
    "smoke:photographer-events": "tsx scripts/smoke/check-photographer-events.ts",
    "smoke:photographer-uploads": "tsx scripts/smoke/check-photographer-uploads.ts",
    "smoke:admin-photographer-upload-review": "tsx scripts/smoke/check-admin-photographer-upload-review.ts",
