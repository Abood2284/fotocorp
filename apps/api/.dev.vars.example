# keep Neon credentials secure: do not expose them to client-side code
DATABASE_URL=postgresql://user:password@host:5432/database

# Better Auth is mounted by this Worker under /api/auth/*.
# Must match BETTER_AUTH_SECRET in apps/web `.env.local` (same DB + same secret for session cookies).
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
FOTOCORP_SUPER_ADMIN_EMAIL=admin@example.com

# Required for signed preview URLs. Store real values in .dev.vars or Wrangler secrets.
MEDIA_PREVIEW_TOKEN_SECRET=replace-with-at-least-32-random-characters
MEDIA_PREVIEW_TOKEN_TTL_SECONDS=1800
# Must match apps/web `.env.local` INTERNAL_API_SECRET. Web proxies /api/auth/* and internal routes here.
INTERNAL_API_SECRET=replace-with-long-random-internal-secret

# Runtime media delivery uses Worker R2 bindings in wrangler.jsonc:
# - MEDIA_PREVIEWS_BUCKET for watermarked derivatives
# - MEDIA_ORIGINALS_BUCKET for canonical Fotokey originals (admin tunnel + subscriber download)
# - MEDIA_CONTRIBUTOR_UPLOADS_BUCKET for contributor pre-approval staging objects (browser PUT target)
# When both staging + originals bindings are present (e.g. `wrangler dev`), contributor **approve**
# copies staging → originals via native R2 get/put without S3 API keys.
# S3-compatible R2 credentials (server-side only; never expose to the browser).
# Contributor direct uploads are **signed by this API** (`POST .../upload-batches/:id/files`), so these
# variables belong in `apps/api/.dev.vars` — not only in `apps/jobs/.env.production`.
#
# Preferred names (aligned with `apps/jobs`):
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_CONTRIBUTOR_STAGING_BUCKET=fotocorp-2026-contributor-uploads
#
# Legacy aliases (still read by the API if the `R2_*` names above are unset):
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_ORIGINALS_BUCKET=fotocorp-2026-megafinal
CLOUDFLARE_R2_PREVIEWS_BUCKET=fotocorp-2026-previews
CLOUDFLARE_R2_CONTRIBUTOR_UPLOADS_BUCKET=fotocorp-2026-contributor-uploads
#
# Bucket roles:
# - Contributor browser PUT presigned URLs target **only** the contributor staging bucket (`R2_CONTRIBUTOR_STAGING_BUCKET`,
#   same name as Worker binding `MEDIA_CONTRIBUTOR_UPLOADS_BUCKET` in wrangler.jsonc).
# - Canonical originals bucket holds Fotokey-named files at root; promotion is server-side (R2 CopyObject), not browser PUT.
#
# R2 CORS (browser PUT): the **contributor staging** bucket needs a CORS rule allowing PUT from your web origin
# (e.g. `http://localhost:3000` in dev, and your deployed Pages/Workers site origin in production). AllowedMethods
# should include `PUT`; AllowedHeaders must allow `Content-Type`. Without CORS, presigned PUT succeeds from curl/Node
# but fails in the browser. Paste JSON in R2 → bucket → Settings → CORS policy. Example file:
#   apps/api/docs/r2-contributor-staging-cors.example.json
# (duplicate each production origin in AllowedOrigins; do not use `*` for production if you can avoid it).
# See ../../docs/db-revamp/reports/photographer-bulk-upload-backend-report.md for context.

# Optional: bootstrap first staff user (never commit real passwords)
# STAFF_BOOTSTRAP_USERNAME=super.admin
# STAFF_BOOTSTRAP_PASSWORD=
# STAFF_BOOTSTRAP_DISPLAY_NAME=Super Admin
# STAFF_BOOTSTRAP_ROLE=SUPER_ADMIN
# PHOTOGRAPHER_SMOKE_USERNAME=ph_000xxx
# PHOTOGRAPHER_SMOKE_PASSWORD=
# PHOTOGRAPHER_UPLOAD_SMOKE_REAL_R2=1
# FOTOKEY_PUBLISH_SMOKE_APPROVE=1
# ADMIN_PHOTOGRAPHER_UPLOAD_REVIEW_SMOKE_APPROVE=1

# Deprecated: do not use for new code. Use explicit ORIGINALS/PREVIEWS/PHOTOGRAPHER_UPLOADS bucket vars.
# CLOUDFLARE_R2_BUCKET=
