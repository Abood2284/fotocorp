# keep Neon credentials secure: do not expose them to client-side code
DATABASE_URL=postgresql://user:password@host:5432/database

# Better Auth is mounted by this Worker under /api/auth/*.
# Must match BETTER_AUTH_SECRET in apps/web `.env.local` (same DB + same secret for session cookies).
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
FOTOCORP_SUPER_ADMIN_EMAIL=admin@example.com

# Required for signed preview URLs. Store real values in .dev.vars or Wrangler secrets.
MEDIA_PREVIEW_TOKEN_SECRET=replace-with-at-least-32-random-characters
MEDIA_PREVIEW_TOKEN_TTL_SECONDS=1800
#
# Public preview CDN (optional). When set, public catalog/homepage/event preview URLs use this
# custom domain instead of same-origin API proxy routes. Originals remain protected behind auth.
PUBLIC_PREVIEW_CDN_BASE_URL=https://media.fotocorp.com
# Bump to v2 after protected-preview backfill + CDN purge (storage_key URLs ignore version)
PUBLIC_PREVIEW_CDN_VERSION=v1
#
# Typesense public search index
# Local dev can use SSH tunnel:
# ssh -N -L 8108:127.0.0.1:8108 root@YOUR_VPS_IP
TYPESENSE_HOST=http://127.0.0.1:8108
TYPESENSE_API_KEY=change-me
TYPESENSE_COLLECTION_ALIAS=public_assets_current
# Caricature segment search collection (defaults to caricatures_current when unset).
TYPESENSE_CARICATURE_COLLECTION_ALIAS=caricatures_current
TYPESENSE_SEARCH_TIMEOUT_MS=1500
# Optional override for GET /api/v1/search/caricatures (defaults to TYPESENSE_SEARCH_TIMEOUT_MS).
TYPESENSE_CARICATURE_SEARCH_TIMEOUT_MS=1500
# Grouped event search uses a higher default timeout (8000ms) unless overridden here.
TYPESENSE_EVENT_SEARCH_TIMEOUT_MS=8000
# Optional for production Typesense behind Cloudflare Tunnel + Access service auth.
# Store real values as Worker secrets, not browser env vars or committed files.
TYPESENSE_CF_ACCESS_CLIENT_ID=
TYPESENSE_CF_ACCESS_CLIENT_SECRET=
#
# Must match apps/web `.env.local` INTERNAL_API_SECRET. Web proxies /api/auth/* and internal routes here.
INTERNAL_API_SECRET=replace-with-long-random-internal-secret

# Shared secret for salted IP hashes in request audit metadata. Set the same value on API and web Workers.
# Prefer 32+ random bytes. If unset, ipHash is stored as null. Do not commit real values.
IP_HASH_SECRET=replace-with-long-random-ip-hash-secret
#
# VPS jobs publish drain wake (PR-3). After staff contributor approval, Worker POSTs here (fire-and-forget).
# `JOBS_DRAIN_WEBHOOK_SECRET` must equal `JOBS_WAKE_SECRET` in `apps/jobs/.env.production` on the VPS.
JOBS_DRAIN_WEBHOOK_URL=https://jobs-internal.fotocorp.com/internal/publish/drain
JOBS_DRAIN_WEBHOOK_SECRET=

# Transactional email for registration/access approval flow.
# Store RESEND_API_KEY as a Cloudflare secret in deployed environments; do not commit real keys.
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=Fotocorp Subscriptions
EMAIL_FROM_ADDRESS=subscription@fotocorp.com
EMAIL_REPLY_TO=subscription@fotocorp.com
RESEND_API_KEY=
# Staff inquiry notifications use hardcoded recipients in apps/api/src/lib/email/email-service.ts
# (STAFF_INQUIRY_NOTIFY_EMAILS). No env gate is required.

# Runtime media delivery uses Worker R2 bindings in wrangler.jsonc:
# - MEDIA_PREVIEWS_BUCKET for watermarked editorial derivatives and blurred caricature previews (`caricatures/{assetId}/...`)
# - MEDIA_ORIGINALS_BUCKET for canonical Fotokey originals (admin tunnel + subscriber download)
# - MEDIA_CONTRIBUTOR_UPLOADS_BUCKET for contributor pre-approval staging objects (browser PUT target)
# - MEDIA_CARICATURE_ORIGINALS_BUCKET for private caricature originals (browser PUT via presigned URL)
# When both staging + originals bindings are present (e.g. `wrangler dev`), contributor **approve**
# copies staging → originals via native R2 get/put without S3 API keys.
# S3-compatible R2 credentials (server-side only; never expose to the browser).
# Contributor direct uploads are **signed by this API** (`POST .../upload-batches/:id/files`), so these
# variables belong in `apps/api/.dev.vars` — not only in `apps/jobs/.env.production`.
#
# Preferred names (aligned with `apps/jobs`):
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_CONTRIBUTOR_STAGING_BUCKET=fotocorp-2026-contributor-uploads
R2_CARICATURE_ORIGINALS_BUCKET=fotocorp-caricature-originals
R2_HELP_CENTER_BUCKET=fotocorp-help-center
R2_PREVIEWS_BUCKET=fotocorp-2026-previews
#
# Legacy aliases (still read by the API if the `R2_*` names above are unset):
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_ORIGINALS_BUCKET=fotocorp-2026-megafinal
CLOUDFLARE_R2_PREVIEWS_BUCKET=fotocorp-2026-previews
CLOUDFLARE_R2_CONTRIBUTOR_UPLOADS_BUCKET=fotocorp-2026-contributor-uploads
#
# Bucket roles:
# - Contributor browser PUT presigned URLs target **only** the contributor staging bucket (`R2_CONTRIBUTOR_STAGING_BUCKET`,
#   same name as Worker binding `MEDIA_CONTRIBUTOR_UPLOADS_BUCKET` in wrangler.jsonc).
# - Canonical originals bucket holds Fotokey-named files at root; promotion is server-side (R2 CopyObject), not browser PUT.
#
# R2 CORS (browser PUT): the **contributor staging** and **caricature originals** buckets need CORS rules allowing PUT from your web origin
# (e.g. `http://localhost:3000` in dev, and your deployed Pages/Workers site origin in production). AllowedMethods
# should include `PUT`; AllowedHeaders must allow `Content-Type`. Without CORS, presigned PUT succeeds from curl/Node
# but fails in the browser. Paste JSON in R2 → bucket → Settings → CORS policy. Example file:
#   apps/api/docs/r2-contributor-staging-cors.example.json
# Staff Help Center media uploads use same-origin BFF PUT (`/api/staff/help/articles/:id/media/:mediaId/upload`) and do **not**
# require R2 CORS on `fotocorp-help-center`. Optional presigned-PUT fallback CORS example:
#   apps/api/docs/r2-help-center-cors.example.json
# (duplicate each production origin in AllowedOrigins; do not use `*` for production if you can avoid it).
# See ../../docs/db-revamp/reports/photographer-bulk-upload-backend-report.md for context.

# Optional: bootstrap first staff user (never commit real passwords)
# STAFF_BOOTSTRAP_USERNAME=super.admin
# STAFF_BOOTSTRAP_PASSWORD=
# STAFF_BOOTSTRAP_DISPLAY_NAME=Super Admin
# STAFF_BOOTSTRAP_ROLE=SUPER_ADMIN
# Caption writers: create via Staff → Staff users (/staff/staff-users), not bootstrap.
# Development: reset a platform USER password (P4 Better Auth hashes are not verifiable by P5 login)
# PLATFORM_DEV_LOGIN_IDENTIFIER=abood
# PLATFORM_DEV_PASSWORD=
# PLATFORM_USER_DELETE_IDENTIFIER=john
# pnpm --dir apps/api db:delete:platform-user
# pnpm --dir apps/api db:sync:contributor-credentials-from-export
# pnpm --dir apps/api db:sync:remaining-contributor-credentials
# PHOTOGRAPHER_SMOKE_USERNAME=ph_000xxx
# PHOTOGRAPHER_SMOKE_PASSWORD=
# PHOTOGRAPHER_UPLOAD_SMOKE_REAL_R2=1
# FOTOKEY_PUBLISH_SMOKE_APPROVE=1
# ADMIN_PHOTOGRAPHER_UPLOAD_REVIEW_SMOKE_APPROVE=1

# Deprecated: do not use for new code. Use explicit ORIGINALS/PREVIEWS/PHOTOGRAPHER_UPLOADS bucket vars.
# CLOUDFLARE_R2_BUCKET=
