# Copy to apps/jobs/.env.production on the VPS (never commit real secrets).
# Aligns with apps/jobs/src/config/env.ts

NODE_ENV=production

# Neon Postgres (required for publish:once / publish:worker; optional for publish:dry-run)
DATABASE_URL=

# Cloudflare R2 (S3-compatible credentials; required for non-dry-run modes)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Staging bucket for photographer uploads (matches API binding name intent)
R2_CONTRIBUTOR_STAGING_BUCKET=
R2_ORIGINALS_BUCKET=
R2_PREVIEWS_BUCKET=

# glibc / libuv tuning (defaults also set in docker-compose.jobs.yml)
MALLOC_ARENA_MAX=2
UV_THREADPOOL_SIZE=2

# Worker loop (used by publish:worker; compose sets safe defaults)
IMAGE_PUBLISH_WORKER_CONCURRENCY=1
IMAGE_PUBLISH_POLL_INTERVAL_MS=15000

# Publish-job processing safety flag (PR-16F):
#   false (default)  → worker counts pending jobs but never claims/mutates them.
#   true             → worker may claim one job and run the placeholder lifecycle
#                      (items + job marked FAILED with PROCESSING_NOT_IMPLEMENTED).
# Real Sharp/R2 processing is not implemented in apps/jobs yet — keep this false
# unless you are intentionally testing the claim/lifecycle path.
IMAGE_PUBLISH_PROCESSING_ENABLED=false
