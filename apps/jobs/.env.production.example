# Copy to apps/jobs/.env.production on the VPS (never commit real secrets).
# Aligns with apps/jobs/src/config/env.ts

NODE_ENV=production

# Neon Postgres (required for publish:once / publish:worker; optional for publish:dry-run)
DATABASE_URL=

# Cloudflare R2 (S3-compatible credentials; required for non-dry-run modes)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional overrides (defaults: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com and region "auto")
# R2_ENDPOINT=
# R2_REGION=
# Contributor upload staging bucket (same logical bucket the API uses for presigned staging PUTs)
R2_CONTRIBUTOR_STAGING_BUCKET=
R2_ORIGINALS_BUCKET=
R2_PREVIEWS_BUCKET=

# glibc / libuv tuning (defaults also set in docker-compose.jobs.yml)
MALLOC_ARENA_MAX=2
UV_THREADPOOL_SIZE=2

# One-shot drain (production default: publish:drain)
PUBLISH_DRAIN_MAX_JOBS=25
PUBLISH_DRAIN_MAX_RUNTIME_SECONDS=300

# Continuous poller (dev/manual only: publish:worker + ALLOW_CONTINUOUS_JOB_WORKER=true)
# ALLOW_CONTINUOUS_JOB_WORKER=true
IMAGE_PUBLISH_WORKER_CONCURRENCY=1
IMAGE_PUBLISH_POLL_INTERVAL_MS=15000

# Publish-job processing safety flag:
#   false (default)  → worker counts queued jobs but does not claim them.
#   true             → worker claims one QUEUED job per iteration and runs real Sharp + R2
#                      publish processing for contributor IMAGE items (PR-16G).
# Keep false until VPS env (Neon + R2) is verified; then set true for GUI end-to-end testing.
IMAGE_PUBLISH_PROCESSING_ENABLED=false

# Post-publish Typesense sync callback (optional; publish still completes when unset)
FOTOCORP_API_BASE_URL=
INTERNAL_API_SECRET=

# Wake HTTP server (publish:wake / fotocorp-jobs-wake) — required for PR-2 tunnel trigger
# Generate a long random value. API Worker `JOBS_DRAIN_WEBHOOK_SECRET` must match exactly.
JOBS_WAKE_SECRET=<long-random-string>
# JOBS_WAKE_BIND_HOST=0.0.0.0
# JOBS_WAKE_PORT=18765
